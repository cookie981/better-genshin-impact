                <!-- 普通锄地选项折叠区域 -->
                <ui:CardExpander Margin="0,0,0,8" ContentPadding="12" IsExpanded="False">
                    <ui:CardExpander.Header>
                        <ui:TextBlock FontTypography="Body" Text="锄地配置选项" />
                    </ui:CardExpander.Header>
                    <StackPanel>
                        <!-- 第一部分：执行配置 -->
                        <ui:TextBlock Margin="16,12,16,4" FontTypography="BodyStrong" Text="第一部分：执行配置" />

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="执行模式" />
                    <ComboBox Grid.Column="1" Width="220" Margin="0,0,36,0" SelectedItem="{Binding Config.AutoHoeingConfig.OperationMode, Mode=TwoWay}">
                        <sys:String>运行锄地路线</sys:String>
                        <sys:String>调试路线分配</sys:String>
                        <sys:String>强制刷新所有运行记录</sys:String>
                        <sys:String>启用仅指定怪物模式</sys:String>
                    </ComboBox>
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="选择执行路径组" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="分组运行时选择对应的路径组编号" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="1" Maximum="10" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.GroupIndex, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="配队名称" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="填写游戏内自定义的队伍名称" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="180" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.PartyName, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="组内路线排序模式" />
                    <ComboBox Grid.Column="1" Width="180" Margin="0,0,36,0" SelectedItem="{Binding Config.AutoHoeingConfig.SortMode, Mode=TwoWay}">
                        <sys:String>原文件顺序</sys:String>
                        <sys:String>效率降序</sys:String>
                        <sys:String>高收益优先</sys:String>
                    </ComboBox>
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="拾取模式" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="推荐使用模板匹配拾取" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="260" Margin="0,0,36,0" SelectedItem="{Binding Config.AutoHoeingConfig.PickupMode, Mode=TwoWay}">
                        <sys:String>模板匹配拾取狗粮和怪物材料</sys:String>
                        <sys:String>模板匹配仅拾取狗粮</sys:String>
                        <sys:String>BGI原版拾取</sys:String>
                        <sys:String>不拾取任何物品</sys:String>
                    </ComboBox>
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="仅使用路线相关怪物材料识别" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.UseRouteRelatedMaterialsOnly, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="禁用二次校验（可能增加误捡）" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.DisableSecondaryValidation, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="泥头车角色编号" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="多个角色用中文逗号分隔，如 1，3" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="120" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.DumperCharacters, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="使用料理名称" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="多个料理用中文逗号分隔，间隔300秒" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="180" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.CookingNames, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="不运行时段" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="如 8，23:11-23:55，用中文逗号分隔" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="180" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.NoRunPeriod, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="识别间隔(ms)" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="10" Maximum="200" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.FindFInterval, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="拾取后延时(ms)" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="16" Maximum="500" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.PickupDelay, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="滚动后延时(ms)" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="16" Maximum="200" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.RollingDelay, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="单次滚动周期(ms)" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="500" Maximum="3000" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.ScrollCycle, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="输出怪物数量日志" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.LogMonsterCount, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="禁用异步操作" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.DisableAsync, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路线结尾坐标检查" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.EnableCoordinateCheck, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="跳过校验阶段" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.SkipValidation, Mode=TwoWay}" />
                </Grid>

                <!-- 第二部分：路线选择与分组配置 -->
                <ui:TextBlock Margin="16,16,16,4" FontTypography="BodyStrong" Text="第二部分：路线选择与分组配置（仅路径组一生效）" />

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="账户名称" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="多账户时填写不同名称区分记录" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="150" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.AccountName, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="路径组一排除标签" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="中文逗号分隔，如 蕈兽，传奇，狭窄地形" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup1, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组二选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup2, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组三选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup3, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组四选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup4, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="禁用自我优化" />
                    <ui:ToggleSwitch Grid.Column="1" Margin="0,0,36,0" IsChecked="{Binding Config.AutoHoeingConfig.DisableSelfOptimization, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="摩拉/耗时权衡因数" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="越大越倾向花时间提高收益，默认0.25" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="0" Maximum="10" SmallChange="0.05" LargeChange="0.1"
                                  SpinButtonPlacementMode="Inline" Value="{Binding Config.AutoHoeingConfig.EfficiencyIndex, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="好奇系数" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="0-1，越大越多尝试未知路线" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="0" Maximum="1" SmallChange="0.1"
                                  SpinButtonPlacementMode="Inline" Value="{Binding Config.AutoHoeingConfig.CuriosityFactor, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="小怪/精英忽略比例" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="比值大于此值的路线忽略精英" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="1" Maximum="1000" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.IgnoreRate, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="目标精英数量" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="0" Maximum="2000" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.TargetEliteNum, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="目标小怪数量" />
                    <ui:NumberBox Grid.Column="1" Width="120" Margin="0,0,36,0" Minimum="0" Maximum="5000" SpinButtonPlacementMode="Inline"
                                  Value="{Binding Config.AutoHoeingConfig.TargetMonsterNum, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="优先关键词" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="中文逗号分隔，含关键词的路线优先选择" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.PriorityTags, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="排除关键词" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="中文逗号分隔，含关键词的路线完全排除" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.ExcludeTags, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组五选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup5, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组六选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup6, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组七选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup7, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组八选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup8, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组九选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup9, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="路径组十选择标签" />
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TagsForGroup10, Mode=TwoWay}" />
                </Grid>

                <!-- 第三部分：仅指定怪物模式 -->
                <ui:TextBlock Margin="16,16,16,4" FontTypography="BodyStrong" Text="第三部分：仅指定怪物模式" />

                <Grid Margin="16,8,16,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="目标怪物" />
                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="中文逗号分隔，按怪物图鉴名称填写" />
                    </StackPanel>
                    <ui:TextBox Grid.Column="1" MinWidth="220" Margin="0,0,36,0" Text="{Binding Config.AutoHoeingConfig.TargetMonsters, Mode=TwoWay}" />
                </Grid>

                    </StackPanel>
                </ui:CardExpander>

                <!-- ========== 联机锄地设置 ========== -->
                <ui:CardExpander Margin="0,12,0,0" ContentPadding="12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <ui:TextBlock FontTypography="Body" Text="联机锄地设置" />
                                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="复用独立任务中的自动战斗配置，另可添加到配置组执行（应用配置组设置）" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" Margin="0,0,12,0"
                                            IsChecked="{Binding Config.AutoHoeingConfig.MultiplayerEnabled, Mode=TwoWay}" />
                        </Grid>
                    </ui:CardExpander.Header>
                    
                    <StackPanel Visibility="{Binding Config.AutoHoeingConfig.MultiplayerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Row="0"
                                          Grid.Column="0"
                                          FontTypography="Body"
                                          Text="联机锄地使用教程"
                                          TextWrapping="Wrap" />
                            <ui:TextBlock Grid.Row="1"
                                          Grid.Column="0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="点击打开联动锄地说明文档"
                                          TextWrapping="Wrap" />
                            <ui:Button Grid.Row="0"
                                       Grid.RowSpan="2"
                                       Grid.Column="1"
                                       Margin="0,0,36,0"
                                       Command="{Binding  OpenutorialCommand}"
                                       Content="打开教程" />
                        </Grid>
                        
                        
                        <!-- ── 身份信息 ── -->
                        <ui:TextBlock Margin="0,10,0,6" FontTypography="BodyStrong" Text="身份信息" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Text="服务器地址（内测中，源码后续开源，可自搭服务器）" />
                            <ui:TextBox Grid.Column="1" Width="220" Margin="0,0,36,0"
                                       Text="{Binding Config.AutoHoeingConfig.CoordinatorServerUrl, Mode=TwoWay}" />
                        </Grid>

                        <!-- 玩家名称 + UID -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <ui:TextBlock Text="玩家名称 / UID" />
                                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="玩家游戏中的名称，UID 用于进入世界" />
                            </StackPanel>
                            <ui:TextBox Grid.Column="1" Width="120" Margin="0,0,8,0"
                                       Text="{Binding Config.AutoHoeingConfig.PlayerName, Mode=TwoWay}"
                                       PlaceholderText="名称" />
                            <ui:TextBox Grid.Column="2" Width="120" Margin="0,0,36,0"
                                       Text="{Binding Config.AutoHoeingConfig.PlayerUid, Mode=TwoWay}"
                                       PlaceholderText="UID" />
                        </Grid>

                        <!-- ========== 联机角色选择 ========== -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <ui:TextBlock Text="联机角色" FontTypography="Body" />
                                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                             Text="选择在联机锄地中的角色定位" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="180" Margin="0,0,36,0"
                                     SelectedIndex="{Binding MultiplayerRoleIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="房主（创建房间）" />
                                <ComboBoxItem Content="成员（加入房间）" />
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,0,36,12" />

                        <!-- ── 房间管理（房主专属）── -->
                        <StackPanel Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:TextBlock Margin="0,0,0,6" FontTypography="BodyStrong" Text="房间管理（房主）" />

                            <!-- 创建房间行 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0" Margin="0,0,8,0" Content="创建房间"
                                          Command="{Binding CreateRoomCommand}" />
                                <ui:TextBox Grid.Column="1" Width="100" Margin="0,0,8,0"
                                           IsReadOnly="True"
                                           Text="{Binding CurrentRoomCode, Mode=OneWay}"
                                           PlaceholderText="房间码" />
                                <ui:Button Grid.Column="2" Margin="0,0,8,0" Content="复制"
                                          Command="{Binding CopyRoomCodeCommand}" />
                                <ui:TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,4,0" Text="人数:" />
                                <ui:NumberBox Grid.Column="4" Width="100" Margin="0,0,8,0" Minimum="2" Maximum="4" SpinButtonPlacementMode="Inline"
                                             Value="{Binding Config.AutoHoeingConfig.ExpectedPlayerCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:Button Grid.Column="5" Margin="0,0,36,0" HorizontalAlignment="Right" Content="关闭房间"
                                          Command="{Binding CloseRoomCommand}" />
                            </Grid>

                            <!-- 房间白名单 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Text="房间白名单（逗号分隔，留空不限制，支持备注名）" />
                                <ui:TextBox Grid.Column="1" MinWidth="180" Margin="0,0,36,0"
                                           Text="{Binding Config.AutoHoeingConfig.RoomWhitelist, Mode=TwoWay}"
                                           PlaceholderText="留空则不限制" />
                            </Grid>
                        </StackPanel>

                        <!-- 加入房间（房主和成员都可见）-->
                        <ui:TextBlock Margin="0,12,0,6" FontTypography="BodyStrong" Text="加入房间" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Margin="0,0,8,0" Content="加入房间"
                                      Command="{Binding JoinRoomCommand}" />
                            <ui:TextBox Grid.Column="1" Width="100" Margin="0,0,8,0"
                                       Text="{Binding Config.AutoHoeingConfig.CurrentRoomCode, Mode=TwoWay}"
                                       PlaceholderText="输入房间码" />
                            <ui:Button Grid.Column="2" Margin="0,0,36,0" Content="浏览房间"
                                      Command="{Binding BrowseRoomsCommand}" />
                        </Grid>

                        <!-- 房间玩家状态 -->
                        <Grid Margin="0,0,0,4">
                            <ui:TextBlock Text="{Binding RoomPlayerSummary}" TextWrapping="Wrap"
                                         Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- 路线差异提示 -->
                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding HasRouteDiff, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <ui:TextBlock Text="路线文件不一致" Foreground="OrangeRed" />
                                <ui:TextBlock Text="{Binding RouteDiffMessage}" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,4,36,12" />

                        <!-- ── 联机队伍和角色准备 ── -->
                        <ui:TextBlock Margin="0,0,0,6" FontTypography="BodyStrong" Text="联机队伍和角色准备" />
                        
                        <!-- 联机队伍名称 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Row="0" Grid.Column="0" 
                                         FontTypography="Body" 
                                         Text="联机队伍名称" 
                                         VerticalAlignment="Center" />
                            <ui:TextBlock Grid.Row="1" Grid.Column="0" 
                                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                         Text="联机前自动切换到指定队伍，留空则使用当前队伍" />
                            <ui:TextBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                       Margin="0,0,36,0"
                                       PlaceholderText="留空则使用当前队伍"
                                       Text="{Binding Config.AutoHoeingConfig.MultiplayerPartyName, Mode=TwoWay}" />
                        </Grid>

                        <!-- 联机起始角色名称 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Row="0" Grid.Column="0" 
                                         FontTypography="Body" 
                                         Text="联机起始角色名称" 
                                         VerticalAlignment="Center" />
                            <ui:TextBlock Grid.Row="1" Grid.Column="0" 
                                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                         Text="联机前自动切换到指定角色，留空则使用当前角色" />
                            <ui:TextBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                       Margin="0,0,36,0"
                                       PlaceholderText="留空则使用当前角色，如：钟离、纳西妲"
                                       Text="{Binding Config.AutoHoeingConfig.MultiplayerStartAvatarName, Mode=TwoWay}" />
                        </Grid>

                        <!-- 说明文字 -->
                        <ui:TextBlock Margin="0,0,0,12" 
                                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     Text="联机前会自动切换到指定队伍和角色，切换失败不影响联机" />

                        <Separator Margin="0,4,36,12"
                                   Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- 房主专属设置说明 -->
                        <ui:TextBlock Margin="0,0,0,8" 
                                     FontSize="11"
                                     Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                     Text="以下设置仅房主设置有效（多轮锄地轮换以第一任房主设置为准）"
                                     Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- ── 房间设置（房主）── -->
                        <Expander Margin="0,0,36,8"
                                  Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Expander.Header>
                                <ui:TextBlock Text="房间设置" FontTypography="BodyStrong" />
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <!-- 组队超时（秒） -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="组队超时（秒）" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="等待队友加入的最长时间" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="60" Maximum="7200" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.PartyTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 超时动作 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="超时动作" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="组队超时后的处理方式" TextWrapping="Wrap" />
                                    <ComboBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="180"
                                              SelectedIndex="{Binding Config.AutoHoeingConfig.PartyTimeoutAction, Mode=TwoWay}">
                                        <ComboBoxItem Content="结束任务" />
                                        <ComboBoxItem Content="现有人数锄地" />
                                    </ComboBox>
                                </Grid>

                                <!-- 多世界连续锄地 -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="多世界连续锄地" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="完成一个世界后按加入顺序轮换房主，最多4轮（使用第一任房主的配置）" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" Margin="0,0,8,0" 
                                                 Minimum="1" Maximum="4" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.MultiWorldCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding Config.AutoHoeingConfig.MultiWorldEnabled}" />
                                    <ui:ToggleSwitch Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                   IsChecked="{Binding Config.AutoHoeingConfig.MultiWorldEnabled, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- ── 同步设置（房主）── -->
                        <Expander Margin="0,4,36,8"
                                  Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Expander.Header>
                                <ui:TextBlock Text="同步设置" FontTypography="BodyStrong" />
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <!-- 集合点超时（秒） -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="集合点超时（秒）" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="等待队友到达集合点的最长时间" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="10" Maximum="300" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.SyncTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 最低同步人数 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="最低同步人数" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="至少需要多少人到达集合点才继续，0表示不限制" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="0" Maximum="4" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.MinPlayersToSync, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 集合点最小距离 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="集合点最小距离" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="路线中相邻集合点的最小距离，用于自动插入集合点" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="5" Maximum="200" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.SyncPointMinDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 万叶玩家序号 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="万叶玩家序号（0=不指定）" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="指定哪位玩家使用万叶聚怪，0表示不指定" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="0" Maximum="4" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.KazuhaPlayerIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 从第几条路线开始 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="从第几条路线开始" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="0：检测锄地CD，1以上：调试时可跳过前N条" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="0" Maximum="999" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.StartRouteIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- 战斗后走回战斗点 -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="战斗后走回战斗点" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="战斗完成后走回战斗点等待其他玩家" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="100" Margin="0,0,8,0" 
                                                 Minimum="0" Maximum="60" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.ReturnToFightPointStaySeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding Config.AutoHoeingConfig.ReturnToFightPointAfterBattle}" />
                                    <ui:ToggleSwitch Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                   IsChecked="{Binding Config.AutoHoeingConfig.ReturnToFightPointAfterBattle, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- ── 战斗配置（房主）── -->
                        <Expander Margin="0,4,36,8"
                                  Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Expander.Header>
                                <ui:TextBlock Text="战斗配置" FontTypography="BodyStrong" />
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <!-- 战斗超时时间（秒） -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontTypography="Body" Text="战斗超时时间（秒）" TextWrapping="Wrap" />
                                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" 
                                                 Text="联机模式下统一的战斗超时，由房主设定并同步给所有成员" TextWrapping="Wrap" />
                                    <ui:NumberBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="120" 
                                                 Minimum="30" Maximum="600" SpinButtonPlacementMode="Inline"
                                                 Value="{Binding Config.AutoHoeingConfig.FightTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- ── 线路选项（折叠）── -->
                        <Expander Margin="0,4,36,8"
                                  Visibility="{Binding IsRoomHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Expander.Header>
                                <ui:TextBlock Text="线路选项" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <ui:TextBlock Text="调试模式" />
                                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="跳过路线一致性验证，方便单人调试" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                   IsChecked="{Binding Config.AutoHoeingConfig.DebugMode, Mode=TwoWay}" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <ui:TextBlock Text="固定调试线路" />
                                        <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="启用后使用内置线路按顺序执行，跳过路线选择" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                   IsChecked="{Binding Config.AutoHoeingConfig.UseFixedDebugRoutes, Mode=TwoWay}" />
                                </Grid>
                                <!-- 手动指定线路目录 - 只在固定调试线路开启时显示 -->
                                <Grid Margin="0,0,0,12" Visibility="{Binding Config.AutoHoeingConfig.UseFixedDebugRoutes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Text="手动指定线路目录" />
                                    <ui:TextBox Grid.Column="1" Width="260"
                                               Text="{Binding Config.AutoHoeingConfig.FixedDebugRoutePath, Mode=TwoWay}"
                                               PlaceholderText="留空则使用下方按钮选择"
                                               TextChanged="OnDebugRoutePathChanged" />
                                </Grid>
                                
                                <!-- 内置线路选择按钮区域 - 只在固定调试线路开启时显示 -->
                                <StackPanel Visibility="{Binding Config.AutoHoeingConfig.UseFixedDebugRoutes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ui:TextBlock Text="内置线路快速选择" 
                                                 Margin="0,0,0,4"
                                                 Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                    <ItemsControl ItemsSource="{Binding BuiltinRoutes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Button Content="{Binding FolderName}"
                                                          Margin="0,0,8,8"
                                                          Appearance="{Binding IsSelected, Converter={StaticResource BoolToButtonAppearanceConverter}}"
                                                          IsEnabled="{Binding IsEnabled}"
                                                          Command="{Binding DataContext.SelectBuiltinRouteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <ui:TextBlock Text="手动输入路径优先级高于按钮选择" 
                                                 Margin="0,4,0,0"
                                                 FontSize="11"
                                                 Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- ── 操作区 ── -->
                        <StackPanel Margin="0,8,0,0">
                            <!-- 按钮行 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" VerticalAlignment="Center"
                                             Text="{Binding MultiplayerStatusText}"
                                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                <ui:Button Grid.Column="1" Margin="0,0,8,0"
                                          Content="开始联机锄地"
                                          Appearance="Primary"
                                          IsEnabled="{Binding CanStartMultiplayer}"
                                          Command="{Binding StartMultiplayerHoeingCommand}" />
                                <ui:Button Grid.Column="2" Margin="0,0,36,0"
                                          Content="立即开始(当前人数)"
                                          IsEnabled="{Binding CanSkipPartyWait}"
                                          Command="{Binding SkipPartyWaitCommand}" />
                            </Grid>
                            <!-- 说明文字 -->
                            <ui:TextBlock Margin="0,6,36,0" 
                                         HorizontalAlignment="Right"
                                         Text="仅在组队等待过程中可用"
                                         FontSize="11"
                                         Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                            <ui:TextBlock Margin="0,2,36,0" 
                                         HorizontalAlignment="Right"
                                         Text="{Binding SkipPartyWaitHotkeyText}"
                                         FontSize="10"
                                         Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ui:CardExpander>

    </StackPanel>
</Page>
