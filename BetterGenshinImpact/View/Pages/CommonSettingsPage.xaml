                                  TextWrapping="Wrap" />
                    <ui:ToggleSwitch Grid.Row="0"
                                     Grid.RowSpan="2"
                                     Grid.Column="1"
                                     HorizontalAlignment="Right"
                                     Margin="0,0,38,0"
                                     IsChecked="{Binding Config.TpConfig.MapMoveStepDivisor, Mode=TwoWay}" />
                    
