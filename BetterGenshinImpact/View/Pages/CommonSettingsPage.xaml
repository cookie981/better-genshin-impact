                                Text="{Binding Config.TpConfig.MapZoomInDistance, Mode=TwoWay, ValidatesOnNotifyDataErrors=True}" 
                                IsEnabled="{Binding Config.TpConfig.MapMoveStepDivisor, Converter={StaticResource InverseBooleanConverter}}"
                                />
