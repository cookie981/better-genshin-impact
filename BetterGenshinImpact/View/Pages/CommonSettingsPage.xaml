                                  VerticalAlignment="Center"
                                  TextWrapping="Wrap"
                                  Visibility="{Binding Config.TpConfig.MapMoveStepDivisor , Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:TextBox Grid.Row="2"
